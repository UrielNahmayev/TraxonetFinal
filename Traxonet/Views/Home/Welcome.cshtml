@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRAXONET - Welcome</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #000000 0%, #1a0000 50%, #000000 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
        }

        /* Animated background particles */
        .bg-particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: rgba(255, 0, 0, 0.3);
            border-radius: 50%;
            animation: float linear infinite;
        }

        @@keyframes float {
            0% {
                transform: translateY(100vh) scale(0);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-10vh) scale(1);
                opacity: 0;
            }
        }

        .welcome-container {
            position: relative;
            z-index: 1;
            max-width: 800px;
            width: 100%;
            animation: containerIn 0.8s ease-out;
        }

        @@keyframes containerIn {
            from {
                opacity: 0;
                transform: translateY(30px) scale(0.97);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        /* Header Section */
        .welcome-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .logo-title {
            font-size: 64px;
            font-weight: 700;
            color: #ff0000;
            text-shadow: 0 0 30px rgba(255, 0, 0, 0.5), 0 0 60px rgba(255, 0, 0, 0.2);
            letter-spacing: 6px;
            margin-bottom: 8px;
            animation: pulseGlow 3s ease-in-out infinite;
        }

        @@keyframes pulseGlow {
            0%, 100% {
                text-shadow: 0 0 30px rgba(255, 0, 0, 0.5), 0 0 60px rgba(255, 0, 0, 0.2);
            }
            50% {
                text-shadow: 0 0 40px rgba(255, 0, 0, 0.7), 0 0 80px rgba(255, 0, 0, 0.3);
            }
        }

        .logo-subtitle {
            font-size: 14px;
            color: #666;
            letter-spacing: 8px;
            text-transform: uppercase;
        }

        .welcome-greeting {
            font-size: 22px;
            color: #ccc;
            margin-top: 20px;
            font-weight: 300;
        }

        .welcome-greeting span {
            color: #ff0000;
            font-weight: 600;
        }

        /* Main Card */
        .main-card {
            background: rgba(0, 0, 0, 0.85);
            border: 2px solid #ff0000;
            border-radius: 20px;
            box-shadow: 0 0 50px rgba(255, 0, 0, 0.15), 0 20px 60px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            position: relative;
        }

        .main-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, #ff0000, transparent);
            animation: scanLine 3s ease-in-out infinite;
        }

        @@keyframes scanLine {
            0%, 100% {
                opacity: 0.5;
            }
            50% {
                opacity: 1;
            }
        }

        /* About Section */
        .about-section {
            padding: 45px 45px 35px;
        }

        .section-label {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }

        .section-label-line {
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, #ff0000, transparent);
        }

        .section-label-text {
            color: #ff0000;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .about-text {
            color: #bbb;
            font-size: 16px;
            line-height: 1.8;
            text-align: center;
        }

        .about-text strong {
            color: #ff0000;
            font-weight: 600;
        }

        /* Features Grid */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            padding: 0 45px 35px;
        }

        .feature-item {
            text-align: center;
            padding: 20px 12px;
            border: 1px solid rgba(255, 0, 0, 0.15);
            border-radius: 12px;
            background: rgba(255, 0, 0, 0.03);
            transition: all 0.3s ease;
        }

        .feature-item:hover {
            border-color: rgba(255, 0, 0, 0.4);
            background: rgba(255, 0, 0, 0.08);
            transform: translateY(-3px);
        }

        .feature-icon {
            font-size: 28px;
            margin-bottom: 10px;
            display: block;
        }

        .feature-name {
            color: #fff;
            font-size: 13px;
            font-weight: 600;
        }

        .feature-desc {
            color: #777;
            font-size: 11px;
            margin-top: 4px;
        }

        /* Divider */
        .divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 0, 0, 0.3), transparent);
            margin: 0 45px;
        }

        /* Actions Section */
        .actions-section {
            padding: 35px 45px 45px;
        }

        .actions-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .action-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 30px 25px;
            border: 2px solid #333;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.02);
            cursor: pointer;
            transition: all 0.4s ease;
            text-decoration: none;
            position: relative;
            overflow: hidden;
        }

        .action-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 0, 0, 0.05), transparent);
            transition: left 0.5s ease;
        }

        .action-card:hover::after {
            left: 100%;
        }

        .action-card:hover {
            border-color: #ff0000;
            background: rgba(255, 0, 0, 0.08);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 0, 0, 0.15);
        }

        .action-icon {
            font-size: 40px;
            margin-bottom: 15px;
            display: block;
            position: relative;
            z-index: 1;
        }

        .action-title {
            color: #fff;
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
            position: relative;
            z-index: 1;
        }

        .action-desc {
            color: #888;
            font-size: 13px;
            line-height: 1.5;
            position: relative;
            z-index: 1;
        }

        .action-btn {
            margin-top: 18px;
            padding: 10px 28px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            position: relative;
            z-index: 1;
        }

        .btn-download {
            background: transparent;
            border: 2px solid #ff0000;
            color: #ff0000;
        }

        .action-card:hover .btn-download {
            background: rgba(255, 0, 0, 0.15);
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.2);
        }

        .btn-dashboard {
            background: linear-gradient(135deg, #ff0000, #cc0000);
            border: none;
            color: #fff;
        }

        .action-card:hover .btn-dashboard {
            box-shadow: 0 5px 25px rgba(255, 0, 0, 0.4);
        }

        /* User Bar */
        .user-bar {
            position: fixed;
            top: 20px;
            right: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            z-index: 1000;
        }

        .user-name {
            color: #999;
            font-size: 14px;
        }

        .logout-btn {
            background: linear-gradient(135deg, #ff416c, #ff4b2b);
            border: none;
            padding: 8px 20px;
            border-radius: 5px;
            color: white;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            font-weight: 600;
            font-size: 13px;
        }

        .logout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(255, 65, 108, 0.4);
        }

        /* Version badge */
        .version-badge {
            text-align: center;
            padding: 15px;
            color: #444;
            font-size: 12px;
            letter-spacing: 1px;
        }

        /* Responsive */
        @@media (max-width: 700px) {
            .logo-title {
                font-size: 40px;
                letter-spacing: 3px;
            }

            .features-grid {
                grid-template-columns: 1fr;
                padding: 0 25px 25px;
            }

            .actions-grid {
                grid-template-columns: 1fr;
            }

            .about-section, .actions-section {
                padding: 25px;
            }

            .divider {
                margin: 0 25px;
            }

            .welcome-greeting {
                font-size: 18px;
            }
        }
    </style>
</head>
<body>
    <!-- Background Particles -->
    <div class="bg-particles" id="bgParticles"></div>

    <!-- User Bar (only when logged in) -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="user-bar">
            <span class="user-name">@User.Identity?.Name</span>
            <form action="/Account/Logout" method="post" style="margin: 0;">
                <button type="submit" class="logout-btn">Logout</button>
            </form>
        </div>
    }

    <div class="welcome-container">
        <!-- Header -->
        <div class="welcome-header">
            <h1 class="logo-title">TRAXONET</h1>
            <div class="logo-subtitle">System Monitoring Platform</div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <p class="welcome-greeting">Welcome, <span>@User.Identity?.Name</span></p>
            }
            else
            {
                <p class="welcome-greeting">Welcome to the <span>monitoring platform</span></p>
            }
        </div>

        <!-- Main Card -->
        <div class="main-card">
            <!-- About Section -->
            <div class="about-section">
                <div class="section-label">
                    <span class="section-label-text">About the Project</span>
                    <div class="section-label-line"></div>
                </div>
                <p class="about-text">
                    <strong>Traxonet</strong> is a real-time system monitoring platform that allows you to track
                    and manage your computers remotely. Install the <strong>Traxonet Client</strong> application
                    on any Windows machine to monitor CPU, GPU, RAM, storage, and temperature data &mdash;
                    all accessible from this secure web dashboard. Configure custom alerts, manage thresholds,
                    and keep your systems running at peak performance.
                </p>
            </div>

            <!-- Features Grid -->
            <div class="features-grid">
                <div class="feature-item">
                    <span class="feature-icon">📡</span>
                    <div class="feature-name">Real-Time Monitoring</div>
                    <div class="feature-desc">Live hardware stats updates</div>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">🔒</span>
                    <div class="feature-name">Encrypted Data</div>
                    <div class="feature-desc">Secure end-to-end communication</div>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">⚡</span>
                    <div class="feature-name">Alert System</div>
                    <div class="feature-desc">Custom threshold notifications</div>
                </div>
            </div>

            <div class="divider"></div>

            <!-- Actions Section -->
            <div class="actions-section">
                <div class="section-label" style="margin-bottom: 25px;">
                    <span class="section-label-text">Get Started</span>
                    <div class="section-label-line"></div>
                </div>

                <div class="actions-grid">
                    <!-- Download Client App -->
                    <a href="/Home/DownloadClient" class="action-card" id="download-action">
                        <span class="action-icon">⬇️</span>
                        <div class="action-title">Download Client</div>
                        <div class="action-desc">
                            Download the Traxonet Client application for Windows to start monitoring your computer.
                        </div>
                        <div class="action-btn btn-download">Download</div>
                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Go to Dashboard (logged in) -->
                        <a href="/Home/GoToDashboard" class="action-card" id="dashboard-action">
                            <span class="action-icon">📊</span>
                            <div class="action-title">Open Dashboard</div>
                            <div class="action-desc">
                                View real-time monitoring data for all your connected devices from the web dashboard.
                            </div>
                            <div class="action-btn btn-dashboard">Enter</div>
                        </a>
                    }
                    else
                    {
                        <!-- Go to Login (not logged in) -->
                        <a href="/Account/Login" class="action-card" id="login-action">
                            <span class="action-icon">🔑</span>
                            <div class="action-title">Login</div>
                            <div class="action-desc">
                                Sign in to your account to access the monitoring dashboard for your devices.
                            </div>
                            <div class="action-btn btn-dashboard">Login</div>
                        </a>
                    }
                </div>
            </div>

            <div class="version-badge">TRAXONET v1.0 &mdash; Secure System Monitoring</div>
        </div>
    </div>

    <script>
        // Create floating background particles
        const particleContainer = document.getElementById('bgParticles');
        const particleCount = 30;

        for (let i = 0; i < particleCount; i++) {
            const particle = document.createElement('div');
            particle.classList.add('particle');
            particle.style.left = Math.random() * 100 + '%';
            particle.style.width = (Math.random() * 3 + 1) + 'px';
            particle.style.height = particle.style.width;
            particle.style.animationDuration = (Math.random() * 10 + 8) + 's';
            particle.style.animationDelay = (Math.random() * 10) + 's';
            particleContainer.appendChild(particle);
        }
    </script>
</body>
</html>
